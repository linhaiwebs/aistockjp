# ===========================================
# 生产环境配置 - ostosk.jp / iswstock.com
# ===========================================
# 重要：部署到生产环境时使用此配置

# API 配置 - 生产环境使用相对路径（推荐）或完整域名
# 选项 1（推荐）：使用相对路径，适合所有代理/反向代理配置
#   VITE_API_URL=（留空）
#   VITE_USE_PROXY=true
# 选项 2：使用完整域名（必须在 CSP 中添加白名单）
#   VITE_API_URL=http://iswstock.com 或 https://ostosk.jp
#   VITE_USE_PROXY=false
VITE_API_URL=
VITE_USE_PROXY=true

# 后端服务器配置
API_PORT=3001
NODE_ENV=production

# SiliconFlow AI 配置
SILICONFLOW_API_KEY=your_siliconflow_api_key_here
SILICONFLOW_API_URL=https://api.siliconflow.cn/v1/chat/completions
SILICONFLOW_MODEL=Qwen/Qwen2.5-7B-Instruct

# JWT 认证配置（生产环境必须使用强随机密钥）
JWT_SECRET=your-super-secret-jwt-key-change-in-production-RANDOM-STRING-HERE

# CORS 配置 - 设置为您的域名
CORS_ORIGIN=https://ostosk.jp

# 代理配置（Nginx/Cloudflare 等）
TRUST_PROXY=true
