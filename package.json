{
  "name": "stock-ai-service",
  "version": "1.0.0",
  "description": "AI Stock Diagnosis Service with PHP traffic routing",
  "private": true,
  "scripts": {
    "install:all": "cd index && npm install",
    "build": "cd index && npm run build",
    "dev:frontend": "cd index && npm run dev",
    "dev:backend": "cd index && npm run server",
    "dev:all": "cd index && npm run dev:all",
    "start": "cd index && npm run start",
    "start:prod": "cd index && npm run start:prod",
    "create-admin": "cd index && npm run create-admin",
    "deploy": "npm run build && docker-compose up -d",
    "deploy:manual": "npm run build && pm2 restart stock-ai-api || pm2 start index/server/index.js --name stock-ai-api",
    "logs": "docker-compose logs -f",
    "stop": "docker-compose down"
  },
  "keywords": [
    "stock",
    "ai",
    "diagnosis",
    "php",
    "react",
    "nodejs"
  ],
  "author": "",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": ""
  }
}
